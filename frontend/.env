# Frontend/.env

# Pi Network Sandbox API
REACT_APP_PI_NETWORK_SANDBOX=https://sandbox.minepi.com/app/palace-of-goods
REACT_APP_PI_NETWORK_SDK_KEY=hyxefkjnrx2o9wh5ek9vcwyoiyc2ewpvjqvgeo5unnneswrepclgle6ndjsl1c1b  # Replace with your Pi Network SDK key

# Backend API URL (Flask)
REACT_APP_API_URL=https://sandbox.minepi.com/app/palace-of-goods  # Update to your backend URL if different

# App Mode
REACT_APP_MODE=development  # Change to 'production' for deployment

# Encryption Key
REACT_APP_ENCRYPTION_KEY=your_encryption_key  # For encrypting sensitive data

# Web3/Blockchain Settings
REACT_APP_WEB3_PROVIDER=

# App Details
REACT_APP_APP_NAME=PalaceOfGoods
REACT_APP_APP_VERSION=1.0.0
